generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "sqlite"
    url      = env("DATABASE_URL")
}

model UserAuth {
    id              String   @id @default(cuid())
    email           String   @unique
    name            String
    passwordHash    String
    username        String   @unique
    avatar          String?
    isEmailVerified Boolean  @default(false)
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt
}
